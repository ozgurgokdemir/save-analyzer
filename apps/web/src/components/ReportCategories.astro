---
import { CheckCircle2 } from 'lucide-react';

const categories = [
  ['Gourd Seeds', 'Exact pickup and shop status'],
  ['Prayer Beads', 'Locations and reconciliation'],
  ['Prosthetic Tools', 'Base tools and upgrades'],
  ['Skills', 'Combat arts and passives'],
  ['Key Items', 'Progression and route items'],
  ['Endings', 'Requirements and availability'],
  ['Bosses', 'Major boss progression'],
  ['Guidance', 'Acquisition details and practical notes'],
] as const;
---

<div
  class="grid gap-px overflow-hidden rounded-2xl border bg-border sm:grid-cols-2 lg:grid-cols-4"
>
  {
    categories.map(([name, copy]) => (
      <article class="bg-card p-6">
        <CheckCircle2
          className="size-5 text-primary"
          aria-hidden="true"
        />
        <h3 class="mt-5 font-semibold">{name}</h3>
        <p class="mt-2 text-sm leading-6 text-muted-foreground">{copy}</p>
      </article>
    ))
  }
</div>
