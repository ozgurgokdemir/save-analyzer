---
import { FileLock2, ShieldCheck, UserRoundX } from "lucide-react"
---

<aside class="privacy-strip" aria-label="Privacy commitments">
  <div class="privacy-point">
    <FileLock2 aria-hidden="true" />
    <span><strong>Local analysis</strong>Your save stays in this browser.</span>
  </div>
  <div class="privacy-point">
    <ShieldCheck aria-hidden="true" />
    <span><strong>Never uploaded</strong>No API or server receives the file.</span>
  </div>
  <div class="privacy-point">
    <UserRoundX aria-hidden="true" />
    <span><strong>No account</strong>No personal data is collected.</span>
  </div>
</aside>
