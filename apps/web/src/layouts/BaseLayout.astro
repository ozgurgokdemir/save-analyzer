---
import '../styles/global.css';
import '../styles/site.css';
import Container from '../components/Container.astro';
import { ThemeToggle } from '../components/ThemeToggle';
import { buttonVariants } from '../components/ui/button';
import { Separator } from '../components/ui/separator';
import { cn } from '../lib/utils';
import { ChevronRight } from 'lucide-react';

interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
}

const { title, description, canonicalPath = Astro.url.pathname } = Astro.props;
const siteName = 'Kindled';
const fullTitle = title === siteName ? title : `${title} · ${siteName}`;
const canonical = new URL(canonicalPath, Astro.site ?? Astro.url.origin);
const ogImage = new URL('/og.png', Astro.site ?? Astro.url.origin);
---

<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <meta name="theme-color" content="#9a4d14" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.ico" sizes="any" />
    <title>{fullTitle}</title>
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta
      property="og:image:alt"
      content="Kindled — private, in-browser Sekiro save analysis"
    />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <script is:inline>
      const getThemePreference = () => {
        const storedTheme = localStorage.getItem('theme');
        if (storedTheme === 'dark' || storedTheme === 'theme-light')
          return storedTheme;
        return window.matchMedia('(prefers-color-scheme: dark)').matches
          ? 'dark'
          : 'theme-light';
      };
      const theme = getThemePreference();
      const isDark = theme === 'dark';
      document.documentElement.classList[isDark ? 'add' : 'remove']('dark');
    </script>
  </head>
  <body class="min-h-screen antialiased">
    <a class="skip-link" href="#main-content">Skip to content</a>
    <header class="sticky top-0 z-50 border-b bg-background">
      <Container class="flex h-16 items-center">
        <a
          href="/"
          class="group inline-flex items-center font-semibold tracking-tight text-lg"
          aria-label="Kindled home"
        >
          <span class="logo-wordmark">Kindled</span>
        </a>
        <nav
          class="ms-4 flex flex-1 items-center gap-1"
          aria-label="Main navigation"
        >
          <a
            class={cn(
              buttonVariants({
                variant: 'ghost',
                className: 'hidden sm:inline-flex',
              }),
            )}
            href="/sekiro/">Sekiro</a
          >
          <a
            class={cn(
              buttonVariants({
                variant: 'ghost',
                className: 'hidden sm:inline-flex',
              }),
            )}
            href="/privacy/">Privacy</a
          >
          <div class="ms-auto flex items-center gap-2">
            <ThemeToggle client:load />
            <Separator
              orientation="vertical"
              className="h-4 data-vertical:self-center"
            />
            <a
              class={cn(buttonVariants({ variant: 'default' }))}
              href="/sekiro/"
            >
              Analyze
              <ChevronRight aria-hidden="true" />
            </a>
          </div>
        </nav>
      </Container>
    </header>
    <main id="main-content">
      <slot />
    </main>
    <footer class="border-t bg-muted/30">
      <Container class="grid gap-8 py-10 sm:grid-cols-2">
        <div>
          <a
            href="/"
            class="group inline-flex items-center font-semibold tracking-tight text-lg"
            aria-label="Kindled home"
          >
            <span class="logo-wordmark">Kindled</span>
          </a>
          <p class="mt-2 max-w-md text-sm leading-6 text-muted-foreground">
            Explore your progress, uncover what you’ve missed, and plan what
            comes next. Your save files never leave your device.
          </p>
        </div>
        <nav
          class="flex flex-wrap self-start gap-x-6 gap-y-2 text-sm sm:justify-end"
          aria-label="Footer navigation"
        >
          <a
            class="text-muted-foreground transition-colors hover:text-foreground"
            href="/sekiro/">Sekiro</a
          >
          <a
            class="text-muted-foreground transition-colors hover:text-foreground"
            href="/privacy/">Privacy</a
          >
        </nav>
      </Container>
    </footer>
  </body>
</html>
